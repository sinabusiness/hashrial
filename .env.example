# ──────────────────────────────────────────────────────────────
# Hashrial Mining Pool - Environment Configuration
# Copy this file to .env and update values for your deployment
# ──────────────────────────────────────────────────────────────

# ── API Configuration ────────────────────────────────────────
API_PORT=4000
JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SITE_URL=https://hashrial.com
# Comma-separated extra origins for local dev (e.g. http://localhost:3000)
CORS_ORIGINS=
LOG_LEVEL=info

# ── Stratum Proxy Configuration ──────────────────────────────
# DNS-only A record pointing directly to your server IP (grey cloud)
# Required — Cloudflare proxies block non-HTTP ports like 3333
STRATUM_HOST=stratum.hashrial.com
PROXY_PORT=3333
MAX_CONNS_PER_IP=20
# Maximum total concurrent proxy connections (memory-limited: ~20KB per connection)
# On 1GB RAM server: max 2000. On 4GB: max 8000.
MAX_TOTAL_CONNS=2000
FEE_PERCENT=2
DISABLE_TLS_VERIFY=false

# ── Antpool Configuration ────────────────────────────────────
# Your Antpool main account username (e.g. "hashrial")
# Users register on Hashrial and are mapped to MAIN_SUBACCOUNT.username sub-accounts on Antpool
# You must create these sub-accounts on Antpool beforehand
ANTPOOL_STRATUM=ss.antpool.com:3333
ANTPOOL_STRATUM_SSL=false
ANTPOOL_API_KEY=xxxxxxxxxxxxx
ANTPOOL_API_SECRET=xxxxxxxxxxxxx
FEE_SUBACCOUNT=hashrialfee
MAIN_SUBACCOUNT=hashrial

# ── Database Configuration (Supabase) ────────────────────────
# Get these from Supabase → Project Settings → Database
POSTGRES_HOST=db.xxxxx.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-password

# ── Redis Configuration (Upstash) ────────────────────────────
# Get these from Upstash Console → Redis Database → Details
REDIS_HOST=xxxxx.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password
# Set REDIS_TLS=true for Upstash (required — uses TLS)
REDIS_TLS=true

# ── Admin Configuration ───────────────────────────────────────
# Comma-separated list of user UUIDs with admin privileges
ADMIN_USER_IDS=

# ── Payout Configuration ─────────────────────────────────────
MIN_PAYOUT_BTC=0.001

# ── Polling Configuration ────────────────────────────────────
# How often to poll Antpool API (in milliseconds)
POLL_INTERVAL_MS=120000
# Data retention in days (hashrate_history, earnings_history, fee_shares, notifications)
DATA_RETENTION_DAYS=90
# COIN_TYPE for Antpool API auth
COIN_TYPE=BTC
